# Nodemailer / contact form (required for POST /api/contact)
# Gmail: use 2FA + App Password (https://myaccount.google.com/apppasswords). SMTP_PASS = 16-char app password, no quotes.
# Omit SMTP_HOST for @gmail.com or set SMTP_HOST=smtp.gmail.com (code uses service: 'gmail' automatically).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Aliases (optional): same as SMTP_USER / SMTP_PASS if you prefer these names
EMAIL_USER=
EMAIL_PASS=
# Company "From" address (must be allowed by your SMTP provider, often same as SMTP_USER)
SMTP_FROM=your.sender@gmail.com
# Display name in the From header (shown to recipients)
MAIL_FROM_NAME=Your Name
# Team inbox — receives submissions (reply goes to the visitor)
CONTACT_TO=your.inbox@gmail.com
